# Local development
DATABASE_URL=postgresql+psycopg2://estimate:estimate_dev@postgres:5432/estimate_tool
SECRET_KEY=dev-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development
LOG_LEVEL=DEBUG
API_V1_PREFIX=/api/v1
FORMULA_VERSION=1.0.0
TEMPLATE_VERSION=1.0.0

# eWorks calculation links (public /eworks/calculate flow)
# EWORKS_LINK_SECRET=change-me-in-staging-production
# EWORKS_LINK_SIG_REQUIRED=false
# EWORKS_SESSION_EXPIRE_MINUTES=480
# eWorks REST API (Customer lookup when opening calculation link)
# EWORKS_API_ENABLED=false
# EWORKS_BASE_URL=https://your-eworks-host
# EWORKS_API_KEY=

# eWorks client quote acceptance sync (disabled by default; local acceptance always succeeds)
# EWORKS_ACCEPTANCE_SYNC_ENABLED=false
# EWORKS_ACCEPTANCE_SYNC_MODE=custom_field
# EWORKS_ACCEPTANCE_CUSTOM_FIELD_ID=45
# EWORKS_ACCEPTANCE_CUSTOM_FIELD_KEY=txtar_45
# When enabled, acceptance notes are written to eWorks custom field txtar_45 via PUT /Quote/{id}.
# Quote/job status changes in eWorks are not implemented in this phase.
# Local client acceptance succeeds even if eWorks sync fails.

# eWorks Quotes/Jobs sync (Phase 22 — read-only from eWorks)
# The sync fetches Quote and Job records from eWorks into local DB tables (eworks_quotes, eworks_jobs).
# This is READ-ONLY: no records are ever written back to eWorks in this phase.
# Trigger sync manually from /admin/eworks-sync in the admin UI.
#
# Required for sync to work:
#   EWORKS_API_ENABLED=true          — must be true (shared with Customer lookup)
#   EWORKS_BASE_URL=https://your-eworks-host
#   EWORKS_API_KEY=<your-api-key>    — NEVER commit this value
#
# Optional behaviour:
#   EWORKS_API_TIMEOUT_SECONDS=30    — HTTP request timeout (default: 30)
#   EWORKS_API_REQUEST_DELAY_SECONDS=0.2
#   EWORKS_API_MAX_RETRIES=3
#   EWORKS_API_RETRY_BACKOFF_SECONDS=2
#
# Endpoints used (read-only GET only):
#   GET {EWORKS_BASE_URL}/Customer   — paginated customer list (override with EWORKS_CUSTOMERS_RESOURCE_PATH)
#   GET {EWORKS_BASE_URL}/Quote      — paginated quote list
#   GET {EWORKS_BASE_URL}/Job        — paginated job list
#
# Optional resource path override:
# EWORKS_CUSTOMERS_RESOURCE_PATH=Customer
#
# Local sync tables created by migration 015+:
#   eworks_quotes, eworks_jobs, eworks_sync_runs, eworks_customers (020)
#
# Scheduled sync is disabled by default. Manual admin-triggered sync remains available.
# Keep background sync disabled locally unless testing.
# Enable on one backend instance only (RUN_BACKGROUND_WORKER=true on a single container/worker).
# If multiple backend replicas run without coordination, each may start its own scheduler.
#
# EWORKS_SYNC_LOOKBACK_DAYS=7
# EWORKS_SYNC_RUNNING_TIMEOUT_MINUTES=30
# Fetch Job detail during sync to extract appointment rows (list payload only has summary counts).
# EWORKS_SYNC_JOB_DETAILS_ENABLED=false
# EWORKS_SYNC_JOB_DETAILS_ONLY_WITH_APPOINTMENTS=true
# EWORKS_SYNC_JOB_DETAILS_LIMIT_PER_RUN=
# EWORKS_SYNC_SALES_APPOINTMENTS_ENABLED=false
# EWORKS_SYNC_QUOTE_DETAILS_FOR_APPOINTMENTS_ENABLED=false
#
# Background scheduler (requires APScheduler in backend):
# Production: run on dedicated worker Container App only (see docs/AZURE_DEPLOYMENT.md).
# API container: RUN_BACKGROUND_WORKER=false, EWORKS_BACKGROUND_SYNC_ENABLED=false
# Worker container: RUN_BACKGROUND_WORKER=true, EWORKS_BACKGROUND_SYNC_ENABLED=true, WEB_CONCURRENCY=1
# EWORKS_BACKGROUND_SYNC_ENABLED=false
# RUN_BACKGROUND_WORKER=false
# EWORKS_BACKGROUND_CUSTOMERS_ENABLED=true
# EWORKS_CUSTOMERS_SYNC_INTERVAL_MINUTES=720
# EWORKS_BACKGROUND_QUOTES_ENABLED=true
# EWORKS_BACKGROUND_JOBS_ENABLED=true
# EWORKS_BACKGROUND_PRODUCTS_ENABLED=true
# EWORKS_BACKGROUND_ATTACHMENTS_ENABLED=true
# EWORKS_QUOTES_SYNC_INTERVAL_MINUTES=15
# EWORKS_JOBS_SYNC_INTERVAL_MINUTES=60
# EWORKS_PRODUCTS_SYNC_INTERVAL_MINUTES=1440
# EWORKS_SYNC_LOCK_TIMEOUT_MINUTES=30
# EWORKS_SYNC_LOCK_HEARTBEAT_SECONDS=60
#
# Attachment metadata sync (Phase 24 — disabled by default):
# When enabled, attachment metadata is extracted from quote/job raw_payload during sync.
# Files are NOT downloaded unless EWORKS_SYNC_ATTACHMENT_FILES_ENABLED=true and download is configured.
#   EWORKS_SYNC_ATTACHMENTS_ENABLED=false
#   EWORKS_SYNC_ATTACHMENT_FILES_ENABLED=false
# Default sync window: last EWORKS_SYNC_LOOKBACK_DAYS (default 7). Use "Full sync" in /admin/eworks-sync for all historical records.
# Raw eWorks payloads are stored in raw_payload (JSON) for debugging; visible to admin only.
# EWORKS_API_ENABLED=false
# EWORKS_BASE_URL=https://your-eworks-host
# EWORKS_API_KEY=

# Storage (local | azure_blob)
STORAGE_BACKEND=local
PDF_STORAGE_PATH=./storage/pdfs

# Azure Blob Storage (when STORAGE_BACKEND=azure_blob)
# AZURE_STORAGE_ACCOUNT_NAME=
# AZURE_STORAGE_CONTAINER_NAME=quote-documents
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_USE_MANAGED_IDENTITY=false
# AZURE_STORAGE_BLOB_PREFIX=quotes

# Key Vault (optional; App Service Key Vault references also supported)
# USE_KEY_VAULT=false
# KEY_VAULT_URL=

# Application Insights
# ENABLE_APPLICATION_INSIGHTS=false
# APPLICATIONINSIGHTS_CONNECTION_STRING=

# Azure OpenAI — Scope rewording
# SCOPE_REWORD_ENABLED=false
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_USE_MANAGED_IDENTITY=false

# Auth provider: dev (local) or azure (Microsoft Entra ID)
# Keep AUTH_PROVIDER and NEXT_PUBLIC_AUTH_PROVIDER in sync (both dev or both azure).
AUTH_PROVIDER=dev
DEV_AUTH_ENABLED=true
DEV_USER_EMAIL=admin@optimal.example
#
# When AUTH_PROVIDER=dev and DEV_USER_EMAIL matches a row in the users table:
#   id, name, role, and is_active come from the database.
# When no matching user exists:
#   identity falls back to DEV_USER_ID, DEV_USER_NAME, DEV_USER_ROLE, DEV_USER_IS_ACTIVE.
# Set DEV_AUTH_AUTO_CREATE_USER=true to create a missing user from env values (default: false).
#
# DEV_USER_ID=dev-user-1
# DEV_USER_NAME=Admin User
# DEV_USER_ROLE=admin
# DEV_USER_IS_ACTIVE=true
# DEV_AUTH_AUTO_CREATE_USER=false
#
# Microsoft Entra ID (production/staging)
# AUTH_PROVIDER=azure
# AZURE_TENANT_ID=
# AZURE_API_CLIENT_ID=
# AZURE_ISSUER=https://login.microsoftonline.com/{tenant_id}/v2.0
# AZURE_JWKS_URL=https://login.microsoftonline.com/{tenant_id}/discovery/v2.0/keys
# Issuer/JWKS URL default from tenant ID when not set explicitly.
# Azure users must exist in the users table; roles always come from DB.

# Frontend (must match AUTH_PROVIDER above)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_AUTH_PROVIDER=dev
# NEXT_PUBLIC_AZURE_TENANT_ID=
# NEXT_PUBLIC_AZURE_CLIENT_ID=
# NEXT_PUBLIC_AZURE_API_SCOPE=api://{backend-api-client-id}/access_as_user
# When NEXT_PUBLIC_AUTH_PROVIDER=azure, /login uses MSAL and protected APIs send Bearer tokens.
# Register redirect URI on the SPA app: http://localhost:3000 (origin only, not /login)
# When NEXT_PUBLIC_AUTH_PROVIDER=dev (default), backend DEV_AUTH_ENABLED handles local auth.
#
# Docker Compose: set AUTH_PROVIDER and NEXT_PUBLIC_AUTH_PROVIDER in this root .env (not only
# backend/.env or frontend/.env.local). They must match — both dev or both azure. NEXT_PUBLIC_*
# vars are baked into the frontend image at build time; run `docker compose up --build` after changes.
#
# Production Azure deploy: copy .env.production.example to .env.production and run ./deploy.sh
# See docs/AZURE_DEPLOYMENT.md for Microsoft login, users table requirements, and validation steps.

