# Staging backend environment (Azure App Service)
ENVIRONMENT=staging
LOG_LEVEL=INFO

# Azure PostgreSQL Flexible Server (append sslmode=require in connection string)
DATABASE_URL=postgresql+psycopg2://estimate_app:<password>@estimate-staging.postgres.database.azure.com:5432/estimate_tool?sslmode=require

# App Service Key Vault reference example:
# SECRET_KEY=@Microsoft.KeyVault(SecretUri=https://estimate-kv-staging.vault.azure.net/secrets/SECRET-KEY/)
SECRET_KEY=replace-with-staging-secret

ACCESS_TOKEN_EXPIRE_MINUTES=480
FRONTEND_URL=https://estimate-staging.azurestaticapps.net
CORS_ORIGINS=https://estimate-staging.azurestaticapps.net
API_V1_PREFIX=/api/v1
FORMULA_VERSION=1.0.0
TEMPLATE_VERSION=1.0.0

# Azure Blob Storage
STORAGE_BACKEND=azure_blob
AZURE_STORAGE_ACCOUNT_NAME=estimatestagingstorage
AZURE_STORAGE_CONTAINER_NAME=quote-documents
AZURE_STORAGE_USE_MANAGED_IDENTITY=true
AZURE_STORAGE_BLOB_PREFIX=quotes

# Application Insights
ENABLE_APPLICATION_INSIGHTS=true
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/

# Optional programmatic Key Vault loading (App Service references are preferred)
USE_KEY_VAULT=false
KEY_VAULT_URL=https://estimate-kv-staging.vault.azure.net/

WEB_CONCURRENCY=2
PORT=8000
RUN_SEED=false
