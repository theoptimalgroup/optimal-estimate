# Production backend environment (Azure App Service)
ENVIRONMENT=production
LOG_LEVEL=WARNING

DATABASE_URL=postgresql+psycopg2://estimate_app:<password>@estimate-prod.postgres.database.azure.com:5432/estimate_tool?sslmode=require

# Use App Service Key Vault references in production — do not commit real secrets.
# SECRET_KEY=@Microsoft.KeyVault(SecretUri=https://estimate-kv-prod.vault.azure.net/secrets/SECRET-KEY/)
# DATABASE_URL=@Microsoft.KeyVault(SecretUri=https://estimate-kv-prod.vault.azure.net/secrets/DATABASE-URL/)
SECRET_KEY=replace-with-production-secret

ACCESS_TOKEN_EXPIRE_MINUTES=480
FRONTEND_URL=https://estimate.optimal.example
CORS_ORIGINS=https://estimate.optimal.example
API_V1_PREFIX=/api/v1
FORMULA_VERSION=1.0.0
TEMPLATE_VERSION=1.0.0

STORAGE_BACKEND=azure_blob
AZURE_STORAGE_ACCOUNT_NAME=estimateprodstorage
AZURE_STORAGE_CONTAINER_NAME=quote-documents
AZURE_STORAGE_USE_MANAGED_IDENTITY=true
AZURE_STORAGE_BLOB_PREFIX=quotes

ENABLE_APPLICATION_INSIGHTS=true
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/

USE_KEY_VAULT=false
KEY_VAULT_URL=https://estimate-kv-prod.vault.azure.net/

WEB_CONCURRENCY=4
PORT=8000
RUN_SEED=false
