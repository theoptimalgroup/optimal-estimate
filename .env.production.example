# Production deployment — copy to .env.production (gitignored) and fill values.
# Used by deploy.sh for frontend Docker build args and backend Container App auth env.
#
# Do NOT commit .env.production — it contains tenant/client IDs for your Azure tenant.

# --- Backend API Container App (runtime) ---
AUTH_PROVIDER=azure
DEV_AUTH_ENABLED=false
AZURE_TENANT_ID=
AZURE_API_CLIENT_ID=

# --- Frontend Docker build (baked into image at build time) ---
NEXT_PUBLIC_AUTH_PROVIDER=azure
NEXT_PUBLIC_API_URL=https://optimal-estimate-api.wonderfulpebble-655f8f4d.northeurope.azurecontainerapps.io
NEXT_PUBLIC_AZURE_TENANT_ID=
NEXT_PUBLIC_AZURE_CLIENT_ID=
# Defaults to api://{AZURE_API_CLIENT_ID}/access_as_user when unset
NEXT_PUBLIC_AZURE_API_SCOPE=

# Optional overrides (deploy.sh falls back to AZURE_TENANT_ID / AZURE_API_CLIENT_ID)
# NEXT_PUBLIC_AZURE_TENANT_ID same as AZURE_TENANT_ID
# NEXT_PUBLIC_AZURE_CLIENT_ID = Entra SPA app registration client ID (not the API app)
