{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous", "authenticated"],
      "rewrite": "https://estimate-api.optimal.example/api/*"
    },
    {
      "route": "/health",
      "rewrite": "https://estimate-api.optimal.example/health"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/health", "/_next/*", "/images/*.{png,jpg,gif,ico,svg,webp}"]
  },
  "responseOverrides": {
    "401": {
      "redirect": "/login",
      "statusCode": 302
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "platform": {
    "apiRuntime": "node:20"
  }
}
